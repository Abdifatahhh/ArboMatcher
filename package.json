{
  "name": "arbomatcher",
  "private": true,
  "version": "0.25.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:portal": "vite build --outDir dist-portal",
    "build:marketing": "vite build --outDir dist-marketing",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "lighthouse:mobile": "lighthouse https://arbomatcher.nl --preset=perf --form-factor=mobile --throttling.cpuSlowdownMultiplier=4 --output=html --output-path=./lighthouse-mobile.html",
    "lighthouse:desktop": "lighthouse https://arbomatcher.nl --preset=perf --form-factor=desktop --output=html --output-path=./lighthouse-desktop.html",
    "lighthouse:mobile:json": "lighthouse https://arbomatcher.nl --preset=perf --form-factor=mobile --throttling.cpuSlowdownMultiplier=4 --output=json --output-path=./lighthouse-mobile.json --quiet",
    "lighthouse:desktop:json": "lighthouse https://arbomatcher.nl --preset=perf --form-factor=desktop --output=json --output-path=./lighthouse-desktop.json --quiet",
    "lighthouse:mobile:edge": "node scripts/lighthouse-edge.mjs https://arbomatcher.nl --preset=perf --form-factor=mobile --throttling.cpuSlowdownMultiplier=4 --output=html --output-path=./lighthouse-mobile.html",
    "lighthouse:desktop:edge": "node scripts/lighthouse-edge.mjs https://arbomatcher.nl --preset=perf --form-factor=desktop --output=html --output-path=./lighthouse-desktop.html",
    "supabase:login": "supabase login",
    "supabase:link": "supabase link --project-ref apizxgqpdledjutgitpw",
    "supabase:deploy": "supabase functions deploy big-check",
    "supabase:deploy-auth-email": "supabase functions deploy send-auth-email --no-verify-jwt",
    "supabase:deploy-kvk-search": "supabase functions deploy kvk-search --no-verify-jwt"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.57.4",
    "lucide-react": "^0.344.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "lighthouse": "^13.0.0",
    "supabase": "^2.19.0",
    "@eslint/js": "^9.9.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^7.3.1"
  }
}
